{
  "name": "nosskey-sdk-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo root for Nosskey SDK and iframe package",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ocknamo/nosskey-sdk.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "format": "biome format --write && biome check --write",
    "format:check": "biome check ./packages ./examples",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "fix": "npm run lint:fix && npm run format",
    "fix:unsafe": "biome check --fix --unsafe"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.14.1",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.4.0",
    "typescript": "~5.8.3",
    "vitest": "^3.1.2"
  },
  "volta": {
    "node": "22.15.0"
  },
  "directories": {
    "doc": "docs",
    "example": "examples"
  }
}
