{
  "name": "nosskey-iframe",
  "version": "0.0.1",
  "description": "iframe signing provider for Nosskey (postMessage bridge for NIP-07 compatible API)",
  "files": [
    "dist",
    "README.md",
    "README.ja.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ocknamo/nosskey-sdk.git",
    "directory": "packages/nosskey-iframe"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nostr",
    "iframe",
    "nip-07",
    "postmessage",
    "signer",
    "passkey",
    "webauthn"
  ],
  "author": "ocknamo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ocknamo/nosskey-sdk/issues"
  },
  "homepage": "https://github.com/ocknamo/nosskey-sdk/tree/main/packages/nosskey-iframe#readme",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "copy-license": "cp ../../LICENSE .",
    "prepublishOnly": "npm run copy-license && npm run build"
  },
  "peerDependencies": {
    "nosskey-sdk": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "nosskey-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "nosskey-sdk": "*",
    "happy-dom": "^20.9.0"
  }
}
